# Vercel environment variables (Project → Settings → Environment Variables)
# Required for prisma-backend build + runtime

NODE_ENV=production

# Supabase / Postgres — Settings → Database → Connect
#
# DATABASE_URL = Transaction pooler (port 6543) — runtime on Vercel
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL = Direct DB (local dev / migrate from your machine)
DIRECT_URL=postgresql://postgres.<ref>:<password>@db.<ref>.supabase.co:5432/postgres
# Optional — only if RUN_MIGRATE_ON_VERCEL=1 (Session pooler, NOT transaction 6543)
# MIGRATE_DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# Auth secrets — use 32+ random chars each (openssl rand -base64 32)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_EMAIL_SECRET=
JWT_PASSWORD_RESET_SECRET=

# Optional — auto-set on Vercel when using unified deploy (same origin)
# API_BASE_URL=https://your-app.vercel.app
# CORS_ORIGIN=https://your-app.vercel.app

# Frontend build (unified deploy — keep default)
# API_BASE_URL=/api/v1

# Seed defaults (run seed locally or via one-off script — not during Vercel build)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
