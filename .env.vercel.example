# Vercel environment variables (Project → Settings → Environment Variables)
# Required for prisma-backend build + runtime

NODE_ENV=production

# Supabase / Postgres (Settings → Database)
DATABASE_URL=postgresql://postgres.<ref>:<password>@<host>:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.<ref>:<password>@<host>:5432/postgres

# Auth secrets — use 32+ random chars each (openssl rand -base64 32)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_EMAIL_SECRET=
JWT_PASSWORD_RESET_SECRET=

# Optional — auto-set on Vercel when using unified deploy (same origin)
# API_BASE_URL=https://your-app.vercel.app
# CORS_ORIGIN=https://your-app.vercel.app

# Frontend build (unified deploy — keep default)
# API_BASE_URL=/api/v1

# Seed defaults (run seed locally or via one-off script — not during Vercel build)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
