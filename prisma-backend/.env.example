NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Supabase → Project Settings → Database → Connect
#
# DATABASE_URL (runtime / Vercel) — Transaction pooler ONLY (port 6543):
#   Mode: Transaction | URI → add ?pgbouncer=true
#   Do NOT use Session pooler (port 5432 on pooler host) on serverless — max 15 clients.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
#
# DIRECT_URL (migrations / prisma migrate) — Direct connection (NOT session pooler):
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@db.<project-ref>.supabase.co:5432/postgres"
SHADOW_DATABASE_URL=""

JWT_ACCESS_SECRET="replace-with-32-plus-random-chars"
JWT_REFRESH_SECRET="replace-with-32-plus-random-chars"
JWT_EMAIL_SECRET="replace-with-32-plus-random-chars"
JWT_PASSWORD_RESET_SECRET="replace-with-32-plus-random-chars"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=30
EMAIL_TOKEN_TTL="30m"
PASSWORD_RESET_TOKEN_TTL="15m"

OTP_TTL_MINUTES=10
OTP_RESEND_SECONDS=60
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

CORS_ORIGIN=http://localhost:4200,http://127.0.0.1:4200,http://localhost:3000

# Default admin (created by npm run seed)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123456


