{
    "name": "angular-v22",
    "version": "1.0.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve --open",
        "build": "ng build",
        "build:vercel": "node scripts/set-env.mjs && ng build --configuration production",
        "vercel-build": "npm run build:vercel",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "lint": "ng lint",
        "lint:fix": "ng lint --fix",
        "format": "prettier --write \"src/**/*.{ts,html,scss,json}\" \"*.{js,json,mjs}\"",
        "format:check": "prettier --check \"src/**/*.{ts,html,scss,json}\" \"*.{js,json,mjs}\""
    },
    "private": true,
    "packageManager": "npm@11.12.1",
    "dependencies": {
        "@angular/animations": "^22.0.0",
        "@angular/cdk": "^22.0.1",
        "@angular/common": "^22.0.0",
        "@angular/compiler": "^22.0.0",
        "@angular/core": "^22.0.0",
        "@angular/forms": "^22.0.0",
        "@angular/platform-browser": "^22.0.0",
        "@angular/platform-browser-dynamic": "^22.0.0",
        "@angular/router": "^22.0.0",
        "@fontsource/poppins": "^5.2.7",
        "@lucide/angular": "^1.18.0",
        "clsx": "^2.1.1",
        "date-fns": "^3.3.1",
        "ngx-quill": "^31.0.1",
        "quill": "^2.0.3",
        "rxjs": "~7.8.0",
        "tailwind-merge": "^3.6.0",
        "tslib": "^2.3.0",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@angular/build": "^22.0.0",
        "@angular/cli": "^22.0.0",
        "@angular/compiler-cli": "^22.0.0",
        "@eslint/js": "^10.0.1",
        "@tailwindcss/forms": "^0.5.7",
        "@types/node": "^20.10.6",
        "angular-eslint": "22.0.0",
        "autoprefixer": "^10.4.16",
        "eslint": "^10.3.0",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "jsdom": "^28.0.0",
        "postcss": "^8.4.32",
        "prettier": "^3.8.1",
        "tailwindcss": "^3.4.1",
        "typescript": "~6.0.2",
        "typescript-eslint": "8.60.1",
        "vitest": "^4.0.8"
    }
}
